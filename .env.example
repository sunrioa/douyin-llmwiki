DASHSCOPE_API_KEY=
SUMMARY_MODEL=qwen-plus
ASR_MODEL=qwen3-asr-flash-filetrans
LOCAL_ASR_MODEL=qwen3-asr-flash
STORAGE_BACKEND=bailian
YT_DLP_COOKIES_FROM_BROWSER=edge
# Optional. Prefer this when you manually export browser cookies in Netscape format.
YT_DLP_COOKIE_FILE=

# URL download backend. Use douyin_crawl when yt-dlp cannot handle Douyin signatures.
DOUYIN_DOWNLOADER=yt-dlp
DOUYIN_CRAWL_PATH=
DOUYIN_COOKIE_FILE=
DOUYIN_DOWNLOAD_DIR=

# Only required when STORAGE_BACKEND=oss.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=

OBSIDIAN_VAULT_PATH=C:\Users\ELAINA\Documents\ObsidianVault
LLMWIKI_DIR=LLMWiki/Douyin
